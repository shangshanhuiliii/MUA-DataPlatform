# Created by .ignore support plugin (hsz.mobi)
### Python template
# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# Distribution / packaging
.Python
.env
env/
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
*.egg-info/
.installed.cfg
*.egg

# PyInstaller
#  Usually these files are written by a python script from a template
#  before PyInstaller builds the exe, so as to inject date/other infos into it.
*.manifest
*.spec

# Installer logs
pip-log.txt
pip-delete-this-directory.txt

# Unit test / coverage reports
htmlcov/
.tox/
.coverage
.coverage.*
.cache
nosetests.xml
coverage.xml
*,cover

# Translations
*.mo
*.pot
!.env.example

# Django stuff:
*.log

# Sphinx documentation
docs/_build/

# PyBuilder
target/
.idea
droidbot_output
_site
Gemfile.lock
.DS_Store
documents
temp
venv

# output_dir
output/*
!output/.gitkeep

# IDEs and editors
.vscode/
.fleet/
.history/
.vs/
.project
.classpath
.settings/
