# ============================================
# DroidBot Web 服务环境变量配置
# ============================================
# ============================================
# 使用说明
# ============================================
# 场景 1 - 开发调试：
#   - 使用 web/ 目录下的 .env.example 不要用这个
#
# 场景 2 - 本地部署：
#   - 在 deploy/ 目录使用此配置
#   - MYSQL_HOST=localhost
#   - 配置 MYSQL_ROOT_PASSWORD, MYSQL_PASSWORD, SECRET_KEY
#
# 场景 3 - 云服务部署：
#   - 在 deploy/ 目录创建 .env.prod
#   - MYSQL_HOST=your-cloud-mysql-host.example.com
#   - 配置 MYSQL_HOST, MYSQL_USER, MYSQL_PASSWORD, SECRET_KEY
#   - 设置 DEBUG=False


# ============================================
# MySQL 数据库配置
# ============================================
# 场景 2（本地部署）：使用 localhost
# 场景 3（云服务部署）：使用云数据库地址
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_DATABASE=droidbot_web
MYSQL_USER=droidbot_user
MYSQL_PASSWORD=your-mysql-password-here

# 场景 2（本地部署）需要配置 root 密码
MYSQL_ROOT_PASSWORD=your-root-password-here

# ============================================
# JWT 认证配置
# ============================================
# 生成方法: openssl rand -hex 32
SECRET_KEY=your-secret-key-here-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ============================================
# 统一会话超时配置
# ============================================
# 部署环境默认值，避免使用极短调试超时
WORKSPACE_IDLE_TIMEOUT_SECONDS=1800
DEVICE_SESSION_IDLE_TIMEOUT_SECONDS=300
RECORDING_RUNTIME_LEASE_SECONDS=90

# ============================================
# WebSocket 心跳配置
# ============================================
WEBSOCKET_PING_INTERVAL_SECONDS=15
WEBSOCKET_PONG_TIMEOUT_SECONDS=10
SESSION_CLEANUP_INTERVAL=20

# ============================================
# 应用配置
# ============================================
DEBUG=False
CORS_ORIGINS=["http://localhost:8888","http://127.0.0.1:8888"]

# ============================================
# 默认管理员配置（首次启动时自动创建）
# ============================================
# 设置 ADMIN_PASSWORD 后，首次启动会自动创建 admin 用户
# 不设置则跳过自动创建，需手动通过 API 注册
ADMIN_PASSWORD=admin123
ADMIN_EMAIL=admin@localhost

# ============================================
# 服务器配置
# ============================================
HOST=0.0.0.0
PORT=8888

# ============================================
# DroidBot 录制配置
# ============================================
DROIDBOT_THREADED_RECORDING=false
# 日志级别: DEBUG, INFO, WARNING, ERROR, CRITICAL
# - DEBUG: 显示所有日志（包括细节信息，用于调试）
# - INFO: 显示性能日志和关键事件（推荐生产环境）
# - WARNING: 仅显示警告和错误
# - ERROR: 仅显示错误
LOG_LEVEL=INFO
MAX_CONCURRENT_DEVICES=5
RECORDING_TIMEOUT=300
RECORDING_CLEANUP_INTERVAL=60

# ============================================
# YoloModelManager配置
# ============================================
YOLO_MAX_QUEUE_SIZE=64      # 预测请求队列最大长度
YOLO_NUM_THREADS=1          # 预测线程数    
YOLO_INFERENCE_TIMEOUT=30    # 预测超时时间（秒）
# 指定模型路径，NONE表示使用droidbot\resources\yolo下最新模型
YOLO_MODEL_PATH=NONE        
YOLO_ONNX_IMGSZ=640         # 输入图像尺寸
YOLO_ONNX_CONF=0.2         # 置信度阈值
YOLO_ONNX_IOU=0.7          # NMS IoU阈值

# ============================================
# 数据存储路径（宿主机路径，用于 Docker volume 挂载）
# ============================================
DATA_DIR=./data

# ============================================
# ADB 配置
# ============================================
# ADB vendor key 文件路径（宿主机路径，替换为实际 key 文件）
ADB_VENDOR_KEYS=/path/to/adb_key

# ============================================
# 火山引擎云手机配置（可选）
# ============================================
# 用于连接火山引擎 ACEP 云手机服务
# 获取方式: https://console.volcengine.com/iam/keymanage/
VOLC_ACCESSKEY=your_access_key
VOLC_SECRETKEY=your_secret_key
VOLC_REGION=cn-north-1
